module RPG
  class AudioFile
    def initialize(name = "", volume = 100, pitch = 100, pos = 0, ch = 2)
      @name = name
      @volume = volume
      @pitch = pitch
      @pos = pos
      @channels = ch
      @type = ""
      @ext = ""
      @seconds = 0.0
      @samples = 0
      @sample_rate = 0
      @loop_start = 0
      @loop_length = 0
    end
    def read(dir)
      Audio.read(self, "Audio/#{dir.upcase}/" + @name)
    end
    def pos
      @pos ||= 0
    end
    def channels
      @channels ||= 2
    end
    def type
      @type ||= ""
    end
    def ext
      @ext ||= ""
    end
    def seconds
      @seconds ||= 0.0
    end
    def samples
      @samples ||= 0
    end
    def sample_rate
      @sample_rate ||= 0
    end
    def loop_start
      @loop_start ||= 0
    end
    def loop_length
      @loop_length ||= 0
    end
    def set_loop(dir, start, length)
      @loop_start = start
      @loop_length = length
      case dir.downcase
      when "bgm"
        Audio.bgm_set_loop(start, length)
      when "bgs"
        Audio.bgs_set_loop(start, length)
      end
    end
    def set_channel_loop(channel, dir, start, length)
      @loop_start = start
      @loop_length = length
      case dir.downcase
      when "bgm"
        Audio.bgms_set_loop(channel, start, length)
      when "bgs"
        Audio.bgss_set_loop(channel, start, length)
      end
    end
    attr_accessor :name, :volume, :pitch
    attr_writer :pos, :channels, :type, :ext, :seconds, :samples, :sample_rate
  end

  class BGM < AudioFile
    @@last = BGM.new
    def play(pos = 0)
      @pos = pos
      if @name.empty?
        Audio.bgm_stop
        @@last = BGM.new
      else
        full_path = "Audio/BGM/" + @name
        Audio.bgm_play(full_path, @volume, @pitch, pos)
        @@last = self.clone
      end
    end
    def replay
      play(@pos)
    end
    def read
      Audio.read(self, "Audio/BGM/" + @name)
    end
    def self.pause
      Audio.bgm_pause
    end
    def self.stop
      Audio.bgm_stop
      @@last = BGM.new
    end
    def self.fade(time)
      Audio.bgm_fade(time)
      @@last = BGM.new
    end
    def self.last
      @@last.pos = Audio.bgm_pos
      @@last
    end
    def set_loop(start, length)
      @loop_start = start
      @loop_length = length
      Audio.bgm_set_loop(start, length)
    end
    def set_channel_loop(channel, start, length)
      @loop_start = start
      @loop_length = length
      Audio.bgms_set_loop(channel, start, length)
    end
    attr_accessor :pos
  end

  class BGS < AudioFile
    @@last = BGS.new
    def play(pos = 0)
      @pos = pos
      if @name.empty?
        Audio.bgs_stop
        @@last = BGS.new
      else
        Audio.bgs_play("Audio/BGS/" + @name, @volume, @pitch, pos)
        @@last = self.clone
      end
    end
    def replay
      play(@pos)
    end
    def read
      Audio.read(self, "Audio/BGS/" + @name)
    end
    def self.pause
      Audio.bgs_pause
    end
    def self.stop
      Audio.bgs_stop
      @@last = BGS.new
    end
    def self.fade(time)
      Audio.bgs_fade(time)
      @@last = BGS.new
    end
    def self.last
      @@last.pos = Audio.bgs_pos
      @@last
    end
    def set_loop(dir, start, length)
      @loop_start = start
      @loop_length = length
      Audio.bgs_set_loop(start, length)
    end
    def set_channel_loop(channel, start, length)
      @loop_start = start
      @loop_length = length
      Audio.bgss_set_loop(channel, start, length)
    end
    attr_accessor :pos
  end

  class ME < AudioFile
    def play
      if @name.empty?
        Audio.me_stop
      else
        Audio.me_play("Audio/ME/" + @name, @volume, @pitch)
      end
    end
    def read
      Audio.read(self, "Audio/ME/" + @name)
    end
    def self.stop
      Audio.me_stop
    end
    def self.fade(time)
      Audio.me_fade(time)
    end
  end

  class SE < AudioFile
    def play
      unless @name.empty?
        Audio.se_play("Audio/SE/" + @name, @volume, @pitch)
      end
    end
    def self.stop
      Audio.se_stop
    end
  end
end
